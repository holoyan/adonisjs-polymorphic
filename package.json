{
  "name": "adonisjs-polymorphic",
  "version": "0.1.0",
  "description": "Polymorphic relations (morphOne, morphMany, morphTo) for AdonisJS Lucid ORM",
  "type": "module",
  "main": "./build/src/index.js",
  "types": "./build/src/index.d.ts",
  "exports": {
    ".": {
      "import": "./build/src/index.js",
      "types": "./build/src/index.d.ts"
    },
    "./provider": {
      "import": "./build/providers/plugin_provider.js",
      "types": "./build/providers/plugin_provider.d.ts"
    },
    "./configure": {
      "import": "./build/configure.js",
      "types": "./build/configure.d.ts"
    },
    "./stubs": {
      "import": "./build/stubs/main.js",
      "types": "./build/stubs/main.d.ts"
    }
  },
  "scripts": {
    "build": "tsc && npm run copy:stubs",
    "copy:stubs": "copyfiles \"stubs/**/*.stub\" build",
    "dev": "tsc --watch",
    "test": "node --import=ts-node-maintained/register/esm bin/test.ts",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "adonisjs",
    "lucid",
    "polymorphic",
    "polymorphic-relations",
    "morph",
    "morphOne",
    "morphMany",
    "morphTo",
    "orm",
    "adonis"
  ],
  "files": [
    "build",
    "!build/bin",
    "!build/tests"
  ],
  "peerDependencies": {
    "@adonisjs/core": ">=6.0.0",
    "@adonisjs/lucid": ">=21.0.0"
  },
  "peerDependenciesMeta": {
    "@adonisjs/core": {
      "optional": false
    }
  },
  "devDependencies": {
    "@adonisjs/assembler": "^7.8.2",
    "@adonisjs/core": "^6.20.0",
    "@adonisjs/lucid": "^21.6.0",
    "@japa/assert": "^4.0.1",
    "@japa/runner": "^4.2.0",
    "@types/node": "^22.0.0",
    "copyfiles": "^2.4.1",
    "pg": "^8.0.0",
    "ts-node-maintained": "^10.9.5",
    "typescript": "~5.8"
  },
  "dependencies": {
    "@holoyan/morph-map-js": "^0.1.2",
    "@poppinss/utils": "^7.0.1",
    "knex": "^3.1.0",
    "luxon": "^3.7.2",
    "reflect-metadata": "^0.2.2"
  }
}
